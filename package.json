{
  "name": "recibos-com-assinatura",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": "server/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "build": "vite build",
    "preview": "node server/index.js",
    "test": "node --test server/*.test.js",
    "build:server": "esbuild server/index.js --bundle --platform=node --format=cjs --target=node24 --outfile=release/sea/server.cjs",
    "build:exe": "npm run build && npm run build:server && powershell -ExecutionPolicy Bypass -File scripts/build-sea-windows.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "postject": "^1.0.0-alpha.6"
  }
}
